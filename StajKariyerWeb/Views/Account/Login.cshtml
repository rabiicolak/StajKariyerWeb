@model StajKariyerWeb.Models.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    .custom-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #f8fafc;
        border-radius: 12px;
        padding: 0.8rem 1rem;
        transition: all 0.3s ease;
    }
    .custom-input:focus {
        background: rgba(255, 255, 255, 0.1);
        border-color: #67e8f9;
        color: #fff;
        box-shadow: 0 0 0 0.25rem rgba(6, 182, 212, 0.25);
    }
    .custom-input::placeholder {
        color: #94a3b8;
    }
    .form-label {
        color: #cbd5e1;
        font-weight: 500;
    }
    .card-icon {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .link-custom {
        color: #67e8f9;
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .link-custom:hover {
        color: #a5b4fc;
        text-decoration: underline;
    }
</style>

<div class="row justify-content-center mt-5 mb-5 fade-in-up">
    <div class="col-md-6 col-lg-5">
        <div class="feature-card shadow-lg">
            <div class="card-body p-sm-4">
                
                <div class="card-icon">🔐</div>
                
                <h2 class="text-center fw-bold hero-title fs-3 mb-2" style="background: linear-gradient(to right, #ffffff, #a5b4fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Hoş Geldin!</h2>
                <p class="text-center text-muted mb-2" style="color: #94a3b8 !important;">Sisteme giriş yaparak kariyer yolculuğuna devam et.</p>
                <p class="text-center mb-4" style="color: #a5b4fc !important; font-size: 0.9em;">Öğrenci veya firma hesabınızla giriş yapabilirsiniz.<br />Sistem sizi rolünüze göre yönlendirecektir.</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.3); color: #ffb3b8;">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3" style="color: #ffb3b8 !important;"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control custom-input" placeholder="ornek@mail.com" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size: 0.85em; color: #ffb3b8 !important;"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control custom-input" placeholder="Şifrenizi girin" />
                        <span asp-validation-for="Password" class="text-danger" style="font-size: 0.85em; color: #ffb3b8 !important;"></span>
                    </div>

                    <button type="submit" class="btn-primary-custom w-100 py-3 mt-2 fs-5">Giriş Yap</button>
                </form>

                <div class="text-center mt-4">
                    <span style="color: #94a3b8;">Hesabın yok mu?</span> 
                    <a href="/Account/Register" class="link-custom fw-bold">Hemen Kayıt Ol</a>
                </div>
            </div>
        </div>
    </div>
</div>