@model StajKariyerWeb.Models.SuitableStudentViewModel

<div class="card h-100 border-0" style="background: rgba(30, 30, 47, 0.7); backdrop-filter: blur(10px); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.2); transition: transform 0.3s ease, box-shadow 0.3s ease;">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <h5 class="fw-bold text-white mb-0" style="font-size: 1.1rem;">@Model.FullName</h5>
            <span class="badge" style="background: linear-gradient(135deg, #10b981, #059669); font-size: 0.9rem; padding: 0.4em 0.8em; border-radius: 8px;">
                %@Model.Score Uyum
            </span>
        </div>
        
        <div class="text-light mb-3" style="font-size: 0.9rem; opacity: 0.8;">
            @if (!string.IsNullOrEmpty(Model.University))
            {
                <div class="mb-1"><i class="me-1">🎓</i> @Model.University</div>
            }
            @if (!string.IsNullOrEmpty(Model.Department))
            {
                <div class="mb-1"><i class="me-1">📚</i> @Model.Department</div>
            }
            @if (!string.IsNullOrEmpty(Model.City))
            {
                <div class="mb-1"><i class="me-1">📍</i> @Model.City</div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.ShortDescription))
        {
            <p class="text-light mb-3" style="font-size: 0.85rem; opacity: 0.7; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @Model.ShortDescription
            </p>
        }

        @if (Model.MatchedFeatures.Any())
        {
            <div class="mb-2">
                <small class="text-light opacity-50 d-block mb-1">Güçlü Yönler:</small>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var feature in Model.MatchedFeatures.Take(4))
                    {
                        <span class="badge" style="background: rgba(16, 185, 129, 0.15); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); font-weight: normal; font-size: 0.75rem;">
                            ✓ @feature
                        </span>
                    }
                    @if (Model.MatchedFeatures.Count > 4)
                    {
                        <span class="badge" style="background: rgba(255, 255, 255, 0.1); color: #fff; border: 1px solid rgba(255, 255, 255, 0.2); font-weight: normal; font-size: 0.75rem;">
                            +@(Model.MatchedFeatures.Count - 4)
                        </span>
                    }
                </div>
            </div>
        }

        @if (Model.MissingSkills != null && Model.MissingSkills.Any())
        {
            <div class="mb-3">
                <small class="text-light opacity-50 d-block mb-1">Eksik Yetkinlikler:</small>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var feature in Model.MissingSkills.Take(3))
                    {
                        <span class="badge" style="background: rgba(239, 68, 68, 0.1); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2); font-weight: normal; font-size: 0.75rem;">
                            - @feature
                        </span>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Insight))
        {
            <div class="p-2 rounded mt-3" style="background: rgba(99, 102, 241, 0.1); border-left: 3px solid #6366f1;">
                <p class="mb-0 text-light" style="font-size: 0.8rem; font-style: italic;">
                    <span style="color: #818cf8; font-weight: bold;">AI Recruiter:</span> @Model.Insight
                </p>
            </div>
        }
        
    </div>
    
    <div class="card-footer bg-transparent border-0 pt-0 pb-4 px-4">
        <div class="d-flex flex-column gap-2">
            @if (!string.IsNullOrEmpty(Model.CVPath))
            {
                <a href="@Model.CVPath" target="_blank" class="btn btn-sm w-100" style="background: rgba(79, 70, 229, 0.2); color: #a5b4fc; border: 1px solid rgba(79, 70, 229, 0.3); border-radius: 8px;">
                    📄 CV Görüntüle
                </a>
            }
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm w-50" style="background: rgba(245, 158, 11, 0.2); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.3); border-radius: 8px;" onclick="alert('Öğrenci favorilere eklendi. (Demo)')">
                    ⭐ Favoriye Ekle
                </button>
                <button type="button" class="btn btn-sm w-50" style="background: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 8px;" onclick="alert('Görüşme daveti gönderildi. (Demo)')">
                    ✉️ Görüşmeye Çağır
                </button>
            </div>
        </div>
    </div>
</div>
