<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StajKariyerWeb</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <!-- Background Blobs -->
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/Home/Index">StajKariyerWeb</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" style="border-color: rgba(255,255,255,0.1);">
                <span class="navbar-toggler-icon" style="background-image: url('data:image/svg+xml;charset=utf8,%3Csvg viewBox=\'0 0 30 30\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath stroke=\'rgba(255, 255, 255, 0.8)\' stroke-width=\'2\' stroke-linecap=\'round\' stroke-miterlimit=\'10\' d=\'M4 7h22M4 15h22M4 23h22\'/%3E%3C/svg%3E');"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto gap-2 align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Index">Ana Sayfa</a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Company"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" style="color: #67e8f9 !important; font-weight: 500;" href="/CompanyDashboard/Index">Firma Paneli</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Companies/Index">Firmalar Listesi</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/EditCompanyProfile">Firma Profilim</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Dashboard/Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Career/Index">Kariyer Eşleştirme</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Roadmap/Index">Yol Haritası</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Companies/Index">Firmalar</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Applications/MyApplications">Başvurularım</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Career/History">Geçmiş Tahminlerim</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Members/Index">Üyeler</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Profile">Hesabım</a>
                            </li>
                        }

                        <li class="nav-item mt-2 mt-lg-0 ms-lg-2">
                            <form asp-action="Logout" asp-controller="Account" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn-outline-custom px-4 text-center w-100" style="display: inline-block; border-color: rgba(220, 53, 69, 0.5); color: #ffb3b8 !important;">Çıkış Yap</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item mt-2 mt-lg-0">
                            <a class="nav-link btn-outline-custom px-4 ms-lg-2 text-center" href="/Account/Register" style="display: inline-block;">Kayıt Ol</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="container">
            © 2026 - Akıllı Staj ve Kariyer Eşleştirme Sistemi | Bilgisayar Mühendisliği Projesi
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>