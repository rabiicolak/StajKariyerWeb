<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StajKariyerWeb</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(180deg, #f4f7fb 0%, #eef3ff 100%);
            font-family: 'Segoe UI', sans-serif;
            color: #1f2937;
        }

        /* Navbar */
        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.3px;
            font-size: 1.4rem;
        }

        .nav-link {
            font-weight: 500;
            transition: 0.2s;
        }

            .nav-link:hover {
                opacity: 0.8;
            }

        /* Kart */
        .card {
            border-radius: 20px;
        }

        /* Buton */
        .btn-main {
            background-color: #0d6efd;
            color: white;
            border: none;
        }

            .btn-main:hover {
                background-color: #0b5ed7;
                color: white;
            }

        /* Footer */
        .footer {
            margin-top: 80px;
            padding: 20px 0;
            text-align: center;
            color: #6c757d;
            font-size: 14px;
        }

        /* Hero */
        .hero-section {
            background: linear-gradient(135deg, #0d6efd 0%, #4f8cff 100%);
            border-radius: 28px;
        }

        /* Feature card */
        .feature-card {
            background: #ffffff;
            border-radius: 22px;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .feature-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 1rem 2rem rgba(13, 110, 253, 0.08) !important;
            }

        .icon-circle {
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background: #e8f0ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .info-box, .stats-box {
            background: #ffffff;
            border-radius: 22px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm py-3">
        <div class="container">

            <a class="navbar-brand" href="/Home/Index">StajKariyerWeb</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Index">Ana Sayfa</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Login">Giriş Yap</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Account/Register">Kayıt Ol</a>
                    </li>

                </ul>
            </div>

        </div>
    </nav>

    <!-- CONTENT -->
    <main class="container py-5">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <div class="footer">
        © 2026 - Akıllı Staj ve Kariyer Eşleştirme Sistemi | Bilgisayar Mühendisliği Projesi
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>