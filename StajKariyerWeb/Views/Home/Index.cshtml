@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="hero-section rounded-4 shadow-sm p-5 p-lg-6 mb-5 text-center text-white">
    <div class="container">
        <span class="badge bg-light text-primary px-3 py-2 mb-3 fs-6">Akıllı Web Platformu</span>
        <h1 class="display-4 fw-bold mb-3">Akıllı Staj ve Kariyer Eşleştirme Sistemi</h1>
        <p class="lead mb-4 hero-subtext">
            Öğrencilerin akademik ve teknik profillerine göre uygun kariyer alanı tahmini yapan ve
            en uygun firmaları öneren modern web tabanlı eşleştirme platformu.
        </p>

        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
            <a href="/Account/Login" class="btn btn-light btn-lg px-4 fw-semibold">Giriş Yap</a>
            <a href="/Account/Register" class="btn btn-outline-light btn-lg px-4 fw-semibold">Kayıt Ol</a>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="feature-card h-100 p-4 shadow-sm">
            <div class="icon-circle mb-3">🎯</div>
            <h4 class="fw-bold mb-3">Kariyer Tahmini</h4>
            <p class="text-muted mb-0">
                Öğrencinin ilgi alanı, proje deneyimi ve teknik becerileri analiz edilerek
                en uygun kariyer alanı tahmin edilir.
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="feature-card h-100 p-4 shadow-sm">
            <div class="icon-circle mb-3">🏢</div>
            <h4 class="fw-bold mb-3">Firma Eşleştirme</h4>
            <p class="text-muted mb-0">
                Tahmin edilen kariyer alanına ve yetkinlik seviyelerine göre firmalar puanlanır,
                en uygun seçenekler önerilir.
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="feature-card h-100 p-4 shadow-sm">
            <div class="icon-circle mb-3">⚡</div>
            <h4 class="fw-bold mb-3">Hızlı ve Kolay Kullanım</h4>
            <p class="text-muted mb-0">
                Kullanıcı dostu arayüz ile öğrenciler bilgilerini girerek saniyeler içinde
                kişiselleştirilmiş öneriler alabilir.
            </p>
        </div>
    </div>
</div>

<div class="row align-items-center g-4 mb-5">
    <div class="col-lg-6">
        <div class="info-box p-4 p-lg-5 shadow-sm">
            <h2 class="fw-bold mb-3">Neden Bu Sistem?</h2>
            <p class="text-muted">
                Geleneksel başvuru süreçlerinde öğrenciler çoğu zaman hangi alana daha uygun olduklarını
                ve hangi firmalara başvurmaları gerektiğini net olarak bilemezler.
            </p>
            <p class="text-muted mb-0">
                Bu sistem, veri odaklı tahmin ve eşleştirme yaklaşımı ile öğrencilere daha bilinçli
                kariyer kararları alma konusunda destek sağlar.
            </p>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="stats-box p-4 p-lg-5 shadow-sm">
            <div class="row text-center g-4">
                <div class="col-4">
                    <h2 class="fw-bold text-primary mb-1">AI</h2>
                    <p class="text-muted mb-0 small">Tahmin Destekli</p>
                </div>
                <div class="col-4">
                    <h2 class="fw-bold text-primary mb-1">Web</h2>
                    <p class="text-muted mb-0 small">Kullanım Kolaylığı</p>
                </div>
                <div class="col-4">
                    <h2 class="fw-bold text-primary mb-1">API</h2>
                    <p class="text-muted mb-0 small">Backend Entegrasyonu</p>
                </div>
            </div>
        </div>
    </div>
</div>