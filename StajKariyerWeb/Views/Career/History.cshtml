@model IEnumerable<StajKariyerWeb.Models.PredictionHistory>

@{
    ViewData["Title"] = "Geçmiş Tahminlerim";
}

<div class="container mt-5 mb-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <div class="icon-wrapper mx-auto" style="width: 70px; height: 70px; border-radius: 50%; background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2)); display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 1.5rem; border: 1px solid rgba(255, 255, 255, 0.05);">🕒</div>
                <h2 class="fw-bold hero-title fs-2 mb-2">Geçmiş Tahminlerim</h2>
                <p class="text-muted" style="color: #94a3b8 !important;">Daha önce yaptığın kariyer analizlerini burada bulabilirsin.</p>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-6">
                            <div class="feature-card shadow-lg h-100 p-4" style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px;">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <span class="badge px-3 py-2" style="background: rgba(6, 182, 212, 0.2); color: #67e8f9; border: 1px solid rgba(6, 182, 212, 0.3);">@item.TahminTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                    <div>
                                        <span class="badge px-3 py-2" style="background: linear-gradient(to right, rgba(79, 70, 229, 0.3), rgba(6, 182, 212, 0.3)); color: #fff; border: 1px solid rgba(255, 255, 255, 0.1);">GNO: @item.GNO</span>
                                    </div>
                                </div>
                                
                                <h4 class="fw-bold text-white mb-2" style="background: linear-gradient(to right, #818cf8, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">@item.Prediction</h4>
                                <h6 class="text-light mb-3">Eşleşen Alan: <span style="color: #67e8f9;">@item.MatchedArea</span></h6>
                                
                                <div class="mt-auto pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
                                    <small class="text-muted" style="color: #94a3b8 !important;"><strong>İlgi Alanı:</strong> @item.IlgiliAlan</small><br />
                                    <small class="text-muted" style="color: #94a3b8 !important;"><strong>Proje:</strong> @item.Proje</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center p-4" style="background: rgba(56, 189, 248, 0.1); border-color: rgba(56, 189, 248, 0.3); color: #bae6fd; border-radius: 16px;">
                    Henüz kayıtlı bir tahmin bulunmuyor. Kariyer Eşleştirme sayfasından ilk analizini yapabilirsin!
                </div>
            }
        </div>
    </div>
</div>
