@model StajKariyerWeb.Models.PredictionRequest
@using StajKariyerWeb.Models

@{
    ViewData["Title"] = "Akıllı Staj ve Kariyer Eşleştirme";
    var result = ViewBag.Result as PredictionResponse;
    var error = ViewBag.Error as string;
    var message = result?.Message;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h2 class="fw-bold mb-4 text-primary">Akıllı Staj ve Kariyer Eşleştirme</h2>

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger">
                            @error
                        </div>
                    }

                    <form asp-action="Index" method="post">
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label asp-for="GNO" class="form-label fw-semibold">GNO</label>
                                <input asp-for="GNO" type="number" step="0.01" min="0" max="4" class="form-control" placeholder="Örn: 2.56" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Ilgili_Alan" class="form-label fw-semibold">İlgili Alan</label>
                                <select asp-for="Ilgili_Alan" class="form-select">
                                    <option value="">İlgili alan seçiniz</option>
                                    <option>Yapay Zeka</option>
                                    <option>Veri Bilimi</option>
                                    <option>Web</option>
                                    <option>Backend</option>
                                    <option>Mobil</option>
                                    <option>Siber Güvenlik</option>
                                    <option>DevOps</option>
                                    <option>Oyun Geliştirme</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label asp-for="Proje" class="form-label fw-semibold">Proje</label>
                                <select asp-for="Proje" class="form-select">
                                    <option value="">Proje seçiniz</option>
                                    <option>Chatbot Geliştirme</option>
                                    <option>Veri Analizi Projesi</option>
                                    <option>Web Sitesi Geliştirme</option>
                                    <option>Mobil Uygulama Geliştirme</option>
                                    <option>Oyun Geliştirme</option>
                                    <option>Siber Güvenlik Aracı</option>
                                    <option>Backend API Geliştirme</option>
                                    <option>DevOps Otomasyon Projesi</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Veritabani" class="form-label fw-semibold">Veritabanı</label>
                                <select asp-for="Veritabani" class="form-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Python" class="form-label fw-semibold">Python</label>
                                <select asp-for="Python" class="form-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Java" class="form-label fw-semibold">Java</label>
                                <select asp-for="Java" class="form-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Csharp" class="form-label fw-semibold">C#</label>
                                <select asp-for="Csharp" class="form-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Cpp" class="form-label fw-semibold">C++</label>
                                <select asp-for="Cpp" class="form-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                </select>
                            </div>

                            <div class="col-12 mt-3">
                                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-3">
                                    Öneri Al
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @if (result != null)
            {
                <div class="card shadow-sm border-0 rounded-4 mt-4">
                    <div class="card-body p-4">
                        <h3 class="fw-bold text-success">Tahmin: @result.Prediction</h3>
                        <h5 class="fw-semibold mt-2">Eşleşen Alan: @result.MatchedArea</h5>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert alert-warning mt-4">
                                @message
                            </div>
                        }
                        else if (result.Companies != null && result.Companies.Any())
                        {
                            <div class="table-responsive mt-4">
                                <table class="table table-bordered table-hover align-middle">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Firma</th>
                                            <th>Alan</th>
                                            <th>Skor</th>
                                            <th>Durum</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var company in result.Companies)
                                        {
                                            <tr>
                                                <td>@company.Firma</td>
                                                <td>@company.IlgiliAlan</td>
                                                <td>@company.Score</td>
                                                <td>
                                                    @if (company.Durum == "Çok Uygun")
                                                    {
                                                        <span class="badge bg-success">@company.Durum</span>
                                                    }
                                                    else if (company.Durum == "Uygun")
                                                    {
                                                        <span class="badge bg-primary">@company.Durum</span>
                                                    }
                                                    else if (company.Durum == "Kısmen Uygun")
                                                    {
                                                        <span class="badge bg-warning text-dark">@company.Durum</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@company.Durum</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mt-4">
                                Gösterilecek öneri bulunamadı.
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>