@model StajKariyerWeb.Models.PredictionRequest
@using StajKariyerWeb.Models

@{
    ViewData["Title"] = "Akıllı Staj ve Kariyer Eşleştirme";
    var result = ViewBag.Result as PredictionResponse;
    var error = ViewBag.Error as string;
}

<div class="container mt-5 mb-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="text-center mb-5">
                <h1 class="fw-bold hero-title mb-3" style="font-size: 2.5rem; background: linear-gradient(to right, #ffffff, #67e8f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    Yapay Zeka ile Kariyer Eşleştirme
                </h1>
                <p class="fs-5 text-light opacity-75">
                    Yetkinliklerini gir, yapay zeka senin için en uygun kariyer alanını ve şirketleri bulsun.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger" style="background: rgba(239, 68, 68, 0.1); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2);">
                    @error
                </div>
            }

            <div class="feature-card shadow-lg">
                <div class="card-body p-sm-5">
                    <form asp-action="Index" method="post">
                        
                        <div class="row g-4">
                            <!-- GNO -->
                            <div class="col-md-6">
                                <label asp-for="GNO" class="form-label text-light fw-semibold">Genel Not Ortalaması (GNO)</label>
                                <input asp-for="GNO" class="form-control" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;" placeholder="Örn: 2.75 veya 3.40" step="0.01" />
                                <small class="text-muted" style="color: #94a3b8 !important; display: block; margin-top: 0.25rem;">4.00 üzerinden genel not ortalamanızı giriniz.</small>
                            </div>

                            <!-- Ilgili_Alan -->
                            <div class="col-md-6">
                                <label asp-for="Ilgili_Alan" class="form-label text-light fw-semibold">İlgi Duyduğun Kariyer Alanı</label>
                                <select asp-for="Ilgili_Alan" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="" style="color: black;">Seçiniz...</option>
                                    <option value="Web" style="color: black;">Web Geliştirme</option>
                                    <option value="Mobil" style="color: black;">Mobil Geliştirme</option>
                                    <option value="Veri_Bilimi" style="color: black;">Veri Bilimi</option>
                                    <option value="Yapay_Zeka" style="color: black;">Yapay Zeka</option>
                                    <option value="Siber_Guvenlik" style="color: black;">Siber Güvenlik</option>
                                    <option value="Oyun" style="color: black;">Oyun Geliştirme</option>
                                </select>
                            </div>

                            <!-- Proje -->
                            <div class="col-md-6">
                                <label asp-for="Proje" class="form-label text-light fw-semibold">Proje Deneyimi</label>
                                <select asp-for="Proje" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="1" style="color: black;">Evet, proje geliştirdim</option>
                                    <option value="0" style="color: black;">Hayır, henüz deneyimim yok</option>
                                </select>
                            </div>

                            <!-- Veritabani -->
                            <div class="col-md-6">
                                <label asp-for="Veritabani" class="form-label text-light fw-semibold">Veritabanı Bilgisi</label>
                                <select asp-for="Veritabani" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="0" style="color: black;">Başlangıç</option>
                                    <option value="1" style="color: black;">Orta</option>
                                    <option value="2" style="color: black;">İleri</option>
                                </select>
                            </div>

                            <div class="col-12 mt-4">
                                <h5 class="fw-bold mb-3 text-light" style="border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">Teknik Yetkinlik Seviyeleri</h5>
                            </div>

                            <!-- Python -->
                            <div class="col-md-6">
                                <label asp-for="Python" class="form-label text-light opacity-75">Python</label>
                                <select asp-for="Python" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="0" style="color: black;">Başlangıç</option>
                                    <option value="1" style="color: black;">Orta</option>
                                    <option value="2" style="color: black;">İleri</option>
                                </select>
                            </div>

                            <!-- Java -->
                            <div class="col-md-6">
                                <label asp-for="Java" class="form-label text-light opacity-75">Java</label>
                                <select asp-for="Java" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="0" style="color: black;">Başlangıç</option>
                                    <option value="1" style="color: black;">Orta</option>
                                    <option value="2" style="color: black;">İleri</option>
                                </select>
                            </div>

                            <!-- Csharp -->
                            <div class="col-md-6">
                                <label asp-for="Csharp" class="form-label text-light opacity-75">C#</label>
                                <select asp-for="Csharp" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="0" style="color: black;">Başlangıç</option>
                                    <option value="1" style="color: black;">Orta</option>
                                    <option value="2" style="color: black;">İyi / Çok İyi</option>
                                </select>
                            </div>

                            <!-- Cpp -->
                            <div class="col-md-6">
                                <label asp-for="Cpp" class="form-label text-light opacity-75">C++</label>
                                <select asp-for="Cpp" class="form-select" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff;">
                                    <option value="0" style="color: black;">Başlangıç</option>
                                    <option value="1" style="color: black;">Orta</option>
                                    <option value="2" style="color: black;">İyi / Çok İyi</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-5 text-center">
                            <button type="submit" class="btn btn-lg px-5" style="background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; border: none; border-radius: 12px; font-weight: 600; box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);">
                                ✨ Kariyerimi Analiz Et
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (result != null)
            {
                <div class="feature-card shadow-lg mt-5 fade-in-up delay-1" id="results">
                    <div class="card-body p-sm-5">

                        <div class="text-center mb-5">
                            <h2 class="hero-title fs-2 mb-3">Analiz Sonuçları</h2>

                            <div class="d-inline-block px-4 py-3 rounded-4 mb-3"
                                 style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2);">

                                <h3 class="fw-bold mb-0" style="color: #34d399;">
                                    Tahmin: @result.Tahmin
                                </h3>

                            </div>

                            <h5 class="fw-semibold text-light">
                                Senin İçin En Uygun Alan:
                                <span style="color: #67e8f9;">
                                    @result.FirmaEslesmeAlani
                                </span>
                            </h5>
                        </div>

                        @if (result.OnerilenFirmalar != null && result.OnerilenFirmalar.Any())
                        {
                            <h4 class="section-title mb-4">Önerilen Firmalar</h4>

                            <div class="row g-4">

                                @foreach (var company in result.OnerilenFirmalar)
                                {
                                    <div class="col-md-6">

                                        <div class="p-4 h-100 d-flex flex-column position-relative" style="background: rgba(30, 30, 47, 0.6); backdrop-filter: blur(10px); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 10px 30px rgba(0,0,0,0.2); transition: transform 0.3s ease;">

                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div class="pe-5">
                                                    <h4 class="fw-bold text-white mb-2" style="font-size: 1.25rem;">
                                                        @company.Firma
                                                    </h4>
                                                    <span class="badge" style="background: rgba(255,255,255,0.1); color: #cbd5e1; font-weight: normal; font-size: 0.85rem;">
                                                        @company.Alan
                                                    </span>
                                                </div>

                                                <div class="position-absolute" style="top: 1.5rem; right: 1.5rem; text-align: center; background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2)); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 0.5rem 0.75rem; color: #67e8f9; min-width: 60px;">
                                                    <span class="d-block fw-bold fs-5 lh-1 mb-1">
                                                        @company.Score
                                                    </span>
                                                    <small class="d-block text-uppercase" style="font-size: 0.65rem; opacity: 0.8;">Puan</small>
                                                </div>
                                            </div>

                                            <div class="mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <span class="text-light opacity-50" style="font-size: 0.85rem;">
                                                        Eşleşme Durumu:
                                                    </span>

                                                    @if (company.Durum == "Çok Uygun")
                                                    {
                                                        <span class="badge px-3 py-2" style="background: rgba(16, 185, 129, 0.2); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.3); font-weight: 500;">
                                                            ⭐ @company.Durum
                                                        </span>
                                                    }
                                                    else if (company.Durum == "Uygun")
                                                    {
                                                        <span class="badge px-3 py-2" style="background: rgba(59, 130, 246, 0.2); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.3); font-weight: 500;">
                                                            👍 @company.Durum
                                                        </span>
                                                    }
                                                    else if (company.Durum == "Kısmen Uygun")
                                                    {
                                                        <span class="badge px-3 py-2" style="background: rgba(245, 158, 11, 0.2); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3); font-weight: 500;">
                                                            🤔 @company.Durum
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge px-3 py-2" style="background: rgba(255,255,255,0.1); color: #cbd5e1; border: 1px solid rgba(255,255,255,0.2); font-weight: 500;">
                                                            @company.Durum
                                                        </span>
                                                    }
                                                </div>
                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info"
                                 style="background: rgba(56, 189, 248, 0.1);
                                                border-color: rgba(56, 189, 248, 0.3);
                                                color: #bae6fd;">

                                Gösterilecek öneri bulunamadı.

                            </div>
                        }

                        @if (ViewBag.Roadmap != null)
                        {
                            var roadmap = ViewBag.Roadmap as List<string>;

                            if (roadmap != null && roadmap.Any())
                            {
                                <div class="mt-5 pt-4"
                                     style="border-top: 1px solid rgba(255,255,255,0.1);">

                                    <div class="text-center mb-4">

                                        <div class="icon-wrapper mx-auto mb-2"
                                             style="width: 50px;
                                                                height: 50px;
                                                                font-size: 1.5rem;">
                                            🗺️
                                        </div>

                                        <h3 class="fw-bold text-light">
                                            Kariyer Yol Haritası
                                        </h3>

                                        <p class="text-muted">
                                            Önerilen alanda gelişmek için izlemen gereken adımlar
                                        </p>

                                    </div>

                                    <div class="row g-3">

                                        @for (int i = 0; i < roadmap.Count; i++)
                                        {
                                            <div class="col-12">

                                                <div class="d-flex align-items-center p-3"
                                                     style="background: rgba(255,255,255,0.03);
                                                                            border: 1px solid rgba(255,255,255,0.1);
                                                                            border-radius: 12px;
                                                                            transition: transform 0.2s;">

                                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                                         style="width: 40px;
                                                                                height: 40px;
                                                                                background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2));
                                                                                color: #67e8f9;
                                                                                font-weight: bold;
                                                                                font-size: 1.1rem;
                                                                                flex-shrink: 0;">

                                                        @(i + 1)

                                                    </div>

                                                    <div class="text-light fs-6">
                                                        @roadmap[i]
                                                    </div>

                                                </div>

                                            </div>
                                        }

                                    </div>

                                </div>
                            }
                        }

                    </div>
                </div>

                <script>
                    document.addEventListener("DOMContentLoaded", function () {

                        const resultsEl = document.getElementById("results");

                        if (resultsEl) {
                            resultsEl.scrollIntoView({
                                behavior: 'smooth',
                                block: 'start'
                            });
                        }
                    });
                </script>
            }
        </div>
    </div>
</div>