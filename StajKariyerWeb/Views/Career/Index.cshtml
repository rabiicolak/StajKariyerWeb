@model StajKariyerWeb.Models.PredictionRequest
@using StajKariyerWeb.Models

@{
    ViewData["Title"] = "Akıllı Staj ve Kariyer Eşleştirme";
    var result = ViewBag.Result as PredictionResponse;
    var error = ViewBag.Error as string;
    var message = result?.Message;
}

<style>
    .custom-input, .custom-select {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #f8fafc !important;
        border-radius: 12px;
        padding: 0.8rem 1rem;
        transition: all 0.3s ease;
    }
    .custom-input:focus, .custom-select:focus {
        background: rgba(255, 255, 255, 0.1) !important;
        border-color: #67e8f9 !important;
        color: #fff !important;
        box-shadow: 0 0 0 0.25rem rgba(6, 182, 212, 0.25) !important;
    }
    .custom-select option {
        background: #0f172a;
        color: #f8fafc;
    }
    .custom-input::placeholder {
        color: #94a3b8;
    }
    .form-label {
        color: #cbd5e1;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }
    .section-title {
        color: #a5b4fc;
        font-weight: 700;
        margin-bottom: 1.5rem;
        margin-top: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 0.5rem;
    }
    .result-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .result-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        border-color: rgba(255, 255, 255, 0.2);
    }
    .badge-score {
        font-size: 1.1rem;
        padding: 0.5rem 1rem;
        border-radius: 12px;
    }
</style>

<div class="container mt-5 mb-5 fade-in-up">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="feature-card shadow-lg mb-5">
                <div class="card-body p-sm-5">
                    <div class="text-center mb-5">
                        <div class="icon-wrapper mx-auto">🤖</div>
                        <h2 class="fw-bold hero-title fs-2 mb-2">Yapay Zeka Destekli Kariyer Testi</h2>
                        <p class="text-muted" style="color: #94a3b8 !important;">Yetkinliklerini gir, sana en uygun kariyer alanını ve şirketleri bulalım.</p>
                    </div>

                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.3); color: #ffb3b8;">
                            @error
                        </div>
                    }

                    <form asp-action="Index" method="post">
                        
                        <h4 class="section-title">Temel Bilgiler</h4>
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label asp-for="GNO" class="form-label">Genel Not Ortalaması (GNO)</label>
                                <input asp-for="GNO" type="number" step="0.01" min="0" max="4" class="form-control custom-input" placeholder="Örn: 2.56 veya 3.40" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Ilgili_Alan" class="form-label">İlgili Alan</label>
                                <select asp-for="Ilgili_Alan" class="form-select custom-select">
                                    <option value="">İlgili alan seçiniz</option>
                                    <option>Yapay Zeka</option>
                                    <option>Veri Bilimi</option>
                                    <option>Web</option>
                                    <option>Backend</option>
                                    <option>Mobil</option>
                                    <option>Siber Güvenlik</option>
                                    <option>DevOps</option>
                                    <option>Oyun Geliştirme</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label asp-for="Proje" class="form-label">Proje Deneyimi</label>
                                <select asp-for="Proje" class="form-select custom-select">
                                    <option value="">Proje seçiniz</option>
                                    <option>Chatbot Geliştirme</option>
                                    <option>Veri Analizi Projesi</option>
                                    <option>Web Sitesi Geliştirme</option>
                                    <option>Mobil Uygulama Geliştirme</option>
                                    <option>Oyun Geliştirme</option>
                                    <option>Siber Güvenlik Aracı</option>
                                    <option>Backend API Geliştirme</option>
                                    <option>DevOps Otomasyon Projesi</option>
                                </select>
                            </div>
                        </div>

                        <h4 class="section-title mt-5">Teknik Yetkinlikler (0-2 Arası Puanlama)</h4>
                        <div class="row g-4 mb-5">
                            <div class="col-md-4">
                                <label asp-for="Veritabani" class="form-label">Veritabanı</label>
                                <select asp-for="Veritabani" class="form-select custom-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0 - Temel / Başlangıç</option>
                                    <option value="1">1 - Orta Seviye (Kullanabilir)</option>
                                    <option value="2">2 - İleri Seviye (Uzman)</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Python" class="form-label">Python</label>
                                <select asp-for="Python" class="form-select custom-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0 - Temel / Başlangıç</option>
                                    <option value="1">1 - Orta Seviye (Kullanabilir)</option>
                                    <option value="2">2 - İleri Seviye (Uzman)</option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Java" class="form-label">Java</label>
                                <select asp-for="Java" class="form-select custom-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0 - Temel / Başlangıç</option>
                                    <option value="1">1 - Orta Seviye (Kullanabilir)</option>
                                    <option value="2">2 - İleri Seviye (Uzman)</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Csharp" class="form-label">C#</label>
                                <select asp-for="Csharp" class="form-select custom-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0 - Temel / Başlangıç</option>
                                    <option value="1">1 - Orta Seviye (Kullanabilir)</option>
                                    <option value="2">2 - İleri Seviye (Uzman)</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Cpp" class="form-label">C++</label>
                                <select asp-for="Cpp" class="form-select custom-select">
                                    <option value="">Seviye seçiniz</option>
                                    <option value="0">0 - Temel / Başlangıç</option>
                                    <option value="1">1 - Orta Seviye (Kullanabilir)</option>
                                    <option value="2">2 - İleri Seviye (Uzman)</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-12 text-center mt-4">
                            <button type="submit" class="btn-primary-custom px-5 py-3 fs-5 w-100">
                                <i class="me-2">⚡</i> Kariyerimi Analiz Et
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (result != null)
            {
                <div class="feature-card shadow-lg mt-5 fade-in-up delay-1" id="results">
                    <div class="card-body p-sm-5">
                        
                        <div class="text-center mb-5">
                            <h2 class="hero-title fs-2 mb-3">Analiz Sonuçları</h2>
                            <div class="d-inline-block px-4 py-3 rounded-4 mb-3" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2);">
                                <h3 class="fw-bold mb-0" style="color: #34d399;">Tahmin: @result.Prediction</h3>
                            </div>
                            <h5 class="fw-semibold text-light">Senin İçin En Uygun Alan: <span style="color: #67e8f9;">@result.MatchedArea</span></h5>
                        </div>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert alert-warning" style="background: rgba(245, 158, 11, 0.1); border-color: rgba(245, 158, 11, 0.3); color: #fcd34d;">
                                @message
                            </div>
                        }
                        else if (result.Companies != null && result.Companies.Any())
                        {
                            <h4 class="section-title mb-4">Önerilen Firmalar</h4>
                            <div class="row g-4">
                                @foreach (var company in result.Companies)
                                {
                                    <div class="col-md-6">
                                        <div class="result-card p-4 h-100 d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div>
                                                    <h4 class="fw-bold text-white mb-1">@company.Firma</h4>
                                                    <span class="text-muted" style="color: #94a3b8 !important;">@company.IlgiliAlan</span>
                                                </div>
                                                <div class="badge-score" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2)); border: 1px solid rgba(255,255,255,0.1); color: #67e8f9;">
                                                    <span class="fw-bold fs-5">@company.Score</span> <small>Puan</small>
                                                </div>
                                            </div>
                                            
                                            <div class="mt-auto pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
                                                <span class="text-muted me-2" style="font-size: 0.9rem;">Eşleşme Durumu:</span>
                                                @if (company.Durum == "Çok Uygun")
                                                {
                                                    <span class="badge bg-success px-3 py-2 fs-6">⭐ @company.Durum</span>
                                                }
                                                else if (company.Durum == "Uygun")
                                                {
                                                    <span class="badge bg-primary px-3 py-2 fs-6">👍 @company.Durum</span>
                                                }
                                                else if (company.Durum == "Kısmen Uygun")
                                                {
                                                    <span class="badge px-3 py-2 fs-6" style="background-color: #f59e0b; color: #fff;">🤔 @company.Durum</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary px-3 py-2 fs-6">@company.Durum</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info" style="background: rgba(56, 189, 248, 0.1); border-color: rgba(56, 189, 248, 0.3); color: #bae6fd;">
                                Gösterilecek öneri bulunamadı.
                            </div>
                        }
                    </div>
                </div>
                
                <script>
                    // Scroll to results if present
                    document.addEventListener("DOMContentLoaded", function() {
                        const resultsEl = document.getElementById("results");
                        if (resultsEl) {
                            resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }
                    });
                </script>
            }

        </div>
    </div>
</div>