@model IEnumerable<StajKariyerWeb.Models.CompanyProfile>

@{
    ViewData["Title"] = "Firma Profilleri";
}

<style>
    .company-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .company-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(6, 182, 212, 0.15);
        border-color: rgba(103, 232, 249, 0.3);
    }
    .company-logo-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 16px;
        overflow: hidden;
        border: 2px solid rgba(103, 232, 249, 0.3);
        background: #1e1e2f;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 1.5rem auto 1rem;
    }
    .company-name {
        background: linear-gradient(to right, #ffffff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
        font-size: 1.25rem;
    }
    .company-info {
        font-size: 0.85rem;
        color: #94a3b8;
    }
    .badge-custom {
        background: rgba(103, 232, 249, 0.1);
        color: #67e8f9;
        border: 1px solid rgba(103, 232, 249, 0.2);
        font-weight: normal;
        padding: 0.4em 0.8em;
    }
</style>

<div class="container mt-5 mb-5 fade-in-up">
    <div class="text-center mb-5">
        <h2 class="fw-bold hero-title fs-2" style="background: linear-gradient(to right, #ffffff, #67e8f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Firma Profilleri</h2>
        <p class="text-muted" style="color: #94a3b8 !important;">Sistemdeki anlaşmalı veya önerilen teknoloji firmalarını inceleyin.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var company in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="company-card shadow-sm">
                        <div class="card-body text-center d-flex flex-column" style="padding-top: 0;">
                            
                            <div class="company-logo-wrapper">
                                @if (!string.IsNullOrEmpty(company.LogoPath))
                                {
                                    <img src="@company.LogoPath" alt="@company.Name" style="width: 100%; height: 100%; object-fit: contain; background: white;" />
                                }
                                else
                                {
                                    <span>🏢</span>
                                }
                            </div>
                            
                            <h5 class="company-name mb-1">@company.Name</h5>
                            
                            <div class="mb-2">
                                <div class="company-info text-light fw-semibold">@company.Sector</div>
                                <div class="company-info">@company.RelatedArea</div>
                            </div>

                            @if (!string.IsNullOrEmpty(company.City))
                            {
                                <div class="mb-3">
                                    <span class="badge rounded-pill badge-custom">📍 @company.City</span>
                                </div>
                            }

                            <div class="mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                                @if (!string.IsNullOrEmpty(company.Description))
                                {
                                    <p class="company-info fst-italic mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        "@company.Description"
                                    </p>
                                }
                                
                                <a href="/Companies/Details/@company.Id" class="btn btn-outline-custom w-100 py-2" style="border-radius: 8px;">
                                    Detayları İncele
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted" style="color: #94a3b8 !important; font-size: 1.1rem;">
                    Sistemde kayıtlı firma bulunamadı.
                </div>
            </div>
        }
    </div>
</div>
