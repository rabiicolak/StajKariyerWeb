@model StajKariyerWeb.Models.MembersViewModel

@{
    ViewData["Title"] = "Üyeler";
}

<style>
    .member-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .member-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(6, 182, 212, 0.15);
        border-color: rgba(103, 232, 249, 0.3);
    }

    .profile-img-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid rgba(103, 232, 249, 0.5);
        box-shadow: 0 0 15px rgba(6, 182, 212, 0.2);
        margin: -40px auto 15px;
        background: #1e1e2f;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .profile-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .card-banner {
        height: 80px;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2));
        border-radius: 16px 16px 0 0;
    }

    .member-name {
        background: linear-gradient(to right, #ffffff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: bold;
        font-size: 1.25rem;
    }

    .member-info {
        font-size: 0.85rem;
        color: #94a3b8;
    }

    .badge-custom {
        background: rgba(103, 232, 249, 0.1);
        color: #67e8f9;
        border: 1px solid rgba(103, 232, 249, 0.2);
        font-weight: normal;
        padding: 0.4em 0.8em;
    }

    .match-badge {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.3);
        font-size: 0.75rem;
        margin-right: 4px;
        margin-bottom: 4px;
    }
</style>

<div class="container mt-5 mb-5 fade-in-up">
    <!-- Similar Members Section -->
    <div class="text-center mb-4">
        <h2 class="fw-bold hero-title fs-2" style="background: linear-gradient(to right, #fcd34d, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Seninle Benzer Profiller</h2>
        <p class="text-muted" style="color: #94a3b8 !important;">Ortak özelliklere sahip olduğunuz topluluk üyeleri.</p>
    </div>

    @if (Model.TopSimilarMembers != null && Model.TopSimilarMembers.Any())
    {
        <div class="row justify-content-center mb-5 g-4">
            @foreach (var sm in Model.TopSimilarMembers)
            {
                var member = sm.User;
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="member-card shadow-sm" style="border-color: rgba(245, 158, 11, 0.4); box-shadow: 0 0 15px rgba(245, 158, 11, 0.1) !important;">
                        <div class="card-banner" style="background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(217, 119, 6, 0.2));"></div>
                        <div class="card-body text-center d-flex flex-column" style="padding-top: 0;">
                            <div class="profile-img-wrapper" style="border-color: rgba(245, 158, 11, 0.5);">
                                @if (!string.IsNullOrEmpty(member.ProfilePhotoPath))
                                {
                                    <img src="@member.ProfilePhotoPath" alt="@member.FullName" />
                                }
                                else
                                {
                                    <span>👤</span>
                                }
                            </div>
                            
                            <h5 class="member-name mb-1" style="background: linear-gradient(to right, #ffffff, #fde68a); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                                @(string.IsNullOrEmpty(member.FullName) ? "İsimsiz Üye" : member.FullName)
                            </h5>
                            
                            <div class="mb-2">
                                <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #fbbf24;">Skor: @sm.SimilarityScore</span>
                            </div>

                            <div class="mb-3 d-flex flex-wrap justify-content-center">
                                @foreach (var reason in sm.MatchReasons)
                                {
                                    <span class="badge rounded-pill match-badge">@reason</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="row justify-content-center mb-5">
            <div class="col-md-8 text-center">
                <div class="alert" style="background: rgba(255, 255, 255, 0.05); border: 1px dashed rgba(255, 255, 255, 0.2); color: #94a3b8;">
                    Henüz benzer profil bulunamadı.
                </div>
            </div>
        </div>
    }

    <!-- All Other Members Section -->
    <hr style="border-color: rgba(255,255,255,0.1); margin-bottom: 3rem;" />
    
    <div class="text-center mb-4">
        <h2 class="fw-bold hero-title fs-3" style="background: linear-gradient(to right, #ffffff, #67e8f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Tüm Topluluk Üyeleri</h2>
    </div>

    <div class="row g-4">
        @if (Model.AllOtherMembers != null && Model.AllOtherMembers.Any())
        {
            foreach (var member in Model.AllOtherMembers)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="member-card shadow-sm">
                        <div class="card-banner"></div>
                        <div class="card-body text-center d-flex flex-column" style="padding-top: 0;">
                            
                            <div class="profile-img-wrapper">
                                @if (!string.IsNullOrEmpty(member.ProfilePhotoPath))
                                {
                                    <img src="@member.ProfilePhotoPath" alt="@member.FullName" />
                                }
                                else
                                {
                                    <span>👤</span>
                                }
                            </div>
                            
                            <h5 class="member-name mb-1">@(string.IsNullOrEmpty(member.FullName) ? "İsimsiz Üye" : member.FullName)</h5>
                            
                            @if (!string.IsNullOrEmpty(member.University) || !string.IsNullOrEmpty(member.Department))
                            {
                                <div class="mb-2">
                                    @if (!string.IsNullOrEmpty(member.University))
                                    {
                                        <div class="member-info text-light fw-semibold">@member.University</div>
                                    }
                                    @if (!string.IsNullOrEmpty(member.Department))
                                    {
                                        <div class="member-info">@member.Department</div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(member.City))
                            {
                                <div class="mb-3">
                                    <span class="badge rounded-pill badge-custom">📍 @member.City</span>
                                </div>
                            }

                            <div class="mt-auto pt-3" style="border-top: 1px solid rgba(255,255,255,0.05);">
                                @if (!string.IsNullOrEmpty(member.ShortDescription))
                                {
                                    <p class="member-info fst-italic mb-0" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        "@member.ShortDescription"
                                    </p>
                                }
                                else
                                {
                                    <p class="member-info fst-italic mb-0" style="opacity: 0.5;">
                                        Henüz bir açıklama eklemedi.
                                    </p>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted" style="color: #94a3b8 !important; font-size: 1.1rem;">
                    Henüz görüntüleyebileceğiniz başka bir üye bulunmuyor.
                </div>
            </div>
        }
    </div>
</div>
