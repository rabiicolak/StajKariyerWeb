@model StajKariyerWeb.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        padding: 1.5rem;
    }

    .dashboard-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(6, 182, 212, 0.15);
        border-color: rgba(103, 232, 249, 0.3);
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.2), rgba(6, 182, 212, 0.2));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .stat-value {
        font-size: 2rem;
        font-weight: bold;
        background: linear-gradient(to right, #ffffff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .stat-label {
        font-size: 0.95rem;
        color: #94a3b8;
    }

    .progress-custom {
        height: 1.2rem;
        background-color: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar-custom {
        background: linear-gradient(to right, #6366f1, #06b6d4);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
        font-size: 0.85rem;
        transition: width 1s ease-in-out;
    }
</style>

<div class="container mt-5 mb-5 fade-in-up">
    <div class="text-center mb-5">
        <h2 class="fw-bold hero-title fs-2" style="background: linear-gradient(to right, #ffffff, #67e8f9); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Kontrol Paneli (Dashboard)</h2>
        <p class="text-muted" style="color: #94a3b8 !important;">Kariyer gelişiminizi ve istatistiklerinizi tek bir yerden takip edin.</p>
    </div>

    <div class="row g-4 mb-4">
        <!-- Toplam Tahmin Sayısı -->
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-card shadow-sm text-center align-items-center">
                <div class="stat-icon">📊</div>
                <div class="stat-value">@Model.TotalPredictions</div>
                <div class="stat-label mt-2">Toplam Kariyer Tahmini</div>
            </div>
        </div>

        <!-- Son Yapılan Tahmin -->
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-card shadow-sm text-center align-items-center">
                <div class="stat-icon">⏱️</div>
                <div class="stat-value" style="font-size: 1.5rem; margin-top: 0.4rem;">
                    @(Model.LastPredictionDate.HasValue ? Model.LastPredictionDate.Value.ToString("dd.MM.yyyy") : "-")
                </div>
                <div class="stat-label mt-2">Son Tahmin Tarihi</div>
            </div>
        </div>

        <!-- En Çok Önerilen Kariyer -->
        <div class="col-md-6 col-lg-6">
            <div class="dashboard-card shadow-sm align-items-center text-center">
                <div class="stat-icon">🎯</div>
                <div class="stat-value" style="font-size: 1.5rem; margin-top: 0.4rem;">
                    @Model.MostRecommendedCareer
                </div>
                <div class="stat-label mt-2">En Çok Önerilen Alan</div>
            </div>
        </div>
    </div>

    <!-- Profil Tamamlama Yüzdesi -->
    <div class="row">
        <div class="col-12">
            <div class="dashboard-card shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold m-0" style="color: #e2e8f0;">Profil Tamamlama Durumu</h5>
                    <span style="color: #67e8f9; font-weight: bold;">%@Model.ProfileCompletionPercentage</span>
                </div>
                <div class="progress progress-custom">
                    <div class="progress-bar progress-bar-custom" role="progressbar" style="width: @Model.ProfileCompletionPercentage%;" aria-valuenow="@Model.ProfileCompletionPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <p class="text-muted mt-3 mb-0" style="font-size: 0.85rem;">Profilinizi ne kadar detaylı doldurursanız (Fotoğraf, CV, Kısa Açıklama vb.) kariyer eşleşmelerinde diğer kullanıcılara o kadar profesyonel görünürsünüz.</p>
                
                @if (Model.ProfileCompletionPercentage < 100)
                {
                    <div class="mt-3 text-end">
                        <a href="/Account/EditProfile" class="btn btn-outline-info btn-sm" style="border-radius: 8px;">Profili Tamamla</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
